            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/credits/balance/", "host": ["{{base_url}}"], "path": ["credits", "balance", ""] }
          }
        },
        {
          "name": "Purchase (simulated)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/credits/purchase/", "host": ["{{base_url}}"], "path": ["credits", "purchase", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100,\n  \"description\": \"Starter pack\"\n}" }
          }
        },
        {
          "name": "Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/credits/transactions/", "host": ["{{base_url}}"], "path": ["credits", "transactions", ""] }
          }
        }
      ]
    },
    {
      "name": "Accessibility (WAVE)",
      "item": [
        {
          "name": "Run Audit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/audits/run/", "host": ["{{base_url}}"], "path": ["audits", "run", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"url\": \"https://www.wikipedia.org\"\n}" },
            "description": "Runs a WAVE accessibility audit. Requires credits — buy some via Credits > Purchase first."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.id) pm.collectionVariables.set('audit_id', d.id);",
                  "pm.test('created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "List Audits",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/audits/?ordering=-created_at",
              "host": ["{{base_url}}"],
              "path": ["audits", ""],
              "query": [
                { "key": "ordering", "value": "-created_at" },
                { "key": "wcag_level", "value": "AA", "disabled": true },
                { "key": "status", "value": "completed", "disabled": true },
                { "key": "url", "value": "wikipedia", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Audit Detail (+ issues)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/audits/{{audit_id}}/", "host": ["{{base_url}}"], "path": ["audits", "{{audit_id}}", ""] }
          }
        },
        {
          "name": "Audit Issues",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/audits/{{audit_id}}/issues/",
              "host": ["{{base_url}}"],
              "path": ["audits", "{{audit_id}}", "issues", ""],
              "query": [
                { "key": "issue_type", "value": "error", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Delete Audit (soft)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/audits/{{audit_id}}/", "host": ["{{base_url}}"], "path": ["audits", "{{audit_id}}", ""] }
          }
        }
      ]
    }
  ]
